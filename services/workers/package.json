{
  "name": "@docket/workers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test:classifier": "tsx src/test/classifier.ts",
    "test:drafter": "tsx src/test/drafter.ts",
    "eval:classify": "tsx scripts/eval-classify.ts",
    "eval:draft": "tsx scripts/eval-draft.ts",
    "eval:discovery": "tsx scripts/eval-discovery.ts",
    "eval:notice": "tsx scripts/eval-notice.ts",
    "e2e:app": "tsx scripts/e2e-app.ts",
    "e2e": "tsx scripts/e2e-app.ts && bun run ../../scripts/protocol-gate.ts --record-e2e-pass",
    "smoke:compose-discovery": "tsx scripts/smoke-compose-discovery-scan.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@docket/db": "workspace:*",
    "@docket/document-processing": "workspace:*",
    "@docket/orchestrator": "workspace:*",
    "@docket/prompts": "workspace:*",
    "@docket/shared": "workspace:*",
    "@docket/discovery-pdf": "workspace:*",
    "@docket/storage": "workspace:*",
    "@docket/tax-graph": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "inngest": "^3.27.4",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
