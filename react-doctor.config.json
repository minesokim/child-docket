{
  "ignore": {
    "rules": [
      "react-doctor/server-auth-actions"
    ],
    "overrides": [
      {
        "files": [
          "src/app/**",
          "src/components/**"
        ],
        "rules": [
          "react-doctor/no-inline-exhaustive-style"
        ]
      },
      {
        "files": [
          "src/icons/**"
        ],
        "rules": [
          "react-doctor/no-giant-component"
        ]
      },
      {
        "files": [
          "src/app/**",
          "src/components/**"
        ],
        "rules": [
          "react-doctor/design-no-em-dash-in-jsx-text"
        ]
      },
      {
        "files": [
          "src/app/(intake)/**",
          "src/app/portal/**",
          "src/components/**"
        ],
        "rules": [
          "react-doctor/no-tiny-text",
          "react-doctor/no-wide-letter-spacing"
        ]
      },
      {
        "files": [
          "src/app/(intake)/**",
          "src/app/portal/**",
          "src/app/(auth)/**"
        ],
        "rules": [
          "react-doctor/nextjs-missing-metadata"
        ]
      }
    ]
  }
}
