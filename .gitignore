# Dependencies
node_modules/
.pnpm-store/

# Build outputs
.next/
.turbo/
dist/
build/
out/
*.tsbuildinfo

# Environment
# Match every .env* variant (.env, .env.local, .env.production, .env.staging,
# .env.development, .env.<anything>.local, etc.) so a new convention added
# upstream can't accidentally bypass gitignore. Allowlist .env.example so the
# template stays tracked.
.env*
!.env.example

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Misc
.cache/
coverage/
.memsearch/

.vercel

# gstack runtime (security reports, incident postmortems, brain queues,
# session timelines). Anything here is an internal developer artifact and
# must not ship to the remote.
.gstack/
