{
  "name": "docket",
  "version": "0.0.1",
  "private": true,
  "description": "Docket — agentic operator for tax practices",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "react-doctor": "npx -y react-doctor@latest -y .",
    "clean": "turbo clean && rm -rf node_modules",
    "e2e:portal": "playwright test",
    "e2e:portal:install": "playwright install chromium",
    "hooks:install": "git config core.hooksPath .githooks && echo 'core.hooksPath set to .githooks/'",
    "hooks:validate-range": "bun run scripts/protocol-gate.ts --range",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.8.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "fast-xml-parser": ">=4.5.3",
      "fast-xml-builder": ">=1.1.7",
      "fast-uri": ">=3.1.2"
    }
  }
}
