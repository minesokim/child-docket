    "seed": "tsx src/seed.ts",
    "seed:reset": "tsx src/seed.ts --reset"
  },
  "dependencies": {
    "@docket/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "dotenv": "^16.4.7"
  }
