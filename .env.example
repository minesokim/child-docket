# Anthropic
ANTHROPIC_API_KEY=

# Postgres
DATABASE_URL=postgres://docket:docket@localhost:5432/docket

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Square (deposit collection — Antonio's existing payment processor)
# Sandbox tokens for dev, production tokens for prod.
# https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox

# DocuSign (8879 e-signature with KBA, IRS Pub 1345 compliant)
# Demo account for dev (free), production account for live.
# https://developers.docusign.com
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# Sentry (error tracking on both apps)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Upstash Redis (rate limiting on hot routes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Storage (Cloudflare R2)
#
# Setup (one-time per environment):
#   1. Cloudflare Console → R2 → Create bucket → name "docket-documents"
#      (or override R2_BUCKET below). Region: Automatic. Public access: OFF.
#   2. R2 → Manage R2 API Tokens → Create API Token
#      Permission: "Object Read & Write"
#      Bucket: scoped to "docket-documents" (or "Apply to all buckets")
#      TTL: forever (rotate via this same flow when needed)
#   3. Copy the credentials into the values below. Account ID is
#      visible in the Cloudflare dashboard top-right under the URL.
#
# The S3 endpoint is derived from R2_ACCOUNT_ID at runtime
# (https://{accountId}.r2.cloudflarestorage.com) — no separate var.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=docket-documents

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Gmail OAuth (per-tenant, encrypted at rest in Postgres)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Encryption key for per-tenant credentials in Postgres (32-byte hex)
TENANT_CREDS_ENC_KEY=

# Field-level encryption for client PII (SSN/EIN/bank) in intake_responses.answers.
# 32-byte AES-256 key in hex. Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=

# Form 8879 mock flow gate.
#
# The /portal/sign-8879 page is a mock until DocuSign + LexisNexis KBA
# lands (Day 13 of the rebuild plan). IRS Pub 1345 requires
# credit-bureau KBA on every remote 8879 signing — the mock has none.
#
# Production: leave UNSET. Real California taxpayers see a "we're
# wiring this up" placeholder; no fake signature, no fabricated tax
# figures, no false legal claim.
#
# Demo / Loom recording: set to `true` to expose the mock flow.
NEXT_PUBLIC_ENABLE_MOCK_8879=
