# Anthropic
ANTHROPIC_API_KEY=

# Postgres
DATABASE_URL=postgres://docket:docket@localhost:5432/docket

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe (deposit + identity for 8879 KYC)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=docket-documents

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Gmail OAuth (per-tenant, encrypted at rest in Postgres)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Encryption key for per-tenant credentials in Postgres (32-byte hex)
TENANT_CREDS_ENC_KEY=

# Field-level encryption for client PII (SSN/EIN/bank) in intake_responses.answers.
# 32-byte AES-256 key in hex. Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=
